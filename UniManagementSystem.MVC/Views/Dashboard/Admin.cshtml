@model UniManagementSystem.Application.DTOs.DashboardDtos.AdminDashboardDto

@{
    ViewData["Title"] = "Admin Dashboard";
}

<link rel="stylesheet" href="~/css/Admin.css" />

<div class="dashboard-layout dashboard-admin">
    <aside class="dashboard-sidebar">
        <div class="dashboard-logo">Learner Admin</div>
        <nav class="dashboard-nav">
            <a asp-controller="Dashboard" asp-action="Admin" class="active"><i class="bi bi-speedometer2"></i> Overview</a>
            <a asp-controller="User" asp-action="Index"><i class="bi bi-people"></i> Users</a>
            <a asp-controller="Courses" asp-action="Index"><i class="bi bi-journal-bookmark"></i> Courses</a>
        </nav>
    </aside>

    <main class="dashboard-main">
        <div class="dashboard-header">
            <h1 class="dashboard-title">Admin Dashboard</h1>
            <span class="dashboard-role-badge">Admin</span>
        </div>

        <div class="card-accent">
            <h5>System Stats</h5>
            <p>Total Students: @Model.TotalStudents</p>
            <p>Total Lecturers: @Model.TotalLecturers</p>
            <p>Total Courses: @Model.TotalCourses</p>
            <p>Total Departments: @Model.TotalDepartments</p>
            <p>Total Fees: @Model.TotalFees.ToString("C")</p>
        </div>

        <div class="card-accent">
            <h5>Recent Notifications</h5>
            <ul>
                @if (Model.RecentNotifications != null && Model.RecentNotifications.Any())
                {
                    foreach (var note in Model.RecentNotifications)
                    {
                        <li>@note.Message (@note.Date.ToString("g"))</li>
                    }
                }
                else
                {
                    <li>No recent notifications.</li>
                }
            </ul>
        </div>

        <div class="card-accent">
            <h5>Courses List</h5>
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Code</th>
                        <th>Department</th>
                        <th>Max Degree</th>
                        <th>Min Degree</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var course in Model.CoursesList ?? new List<UniManagementSystem.Application.DTOs.DashboardDtos.CourseDto>())
                    {
                        <tr>
                            <td>@course.Name</td>
                            <td>@course.Code</td>
                            <td>@course.Department</td>
                            <td>@course.MaxDegree</td>
                            <td>@course.MinDegree</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="card-accent">
            <h5>Departments List</h5>
            <ul>
                @foreach (var dept in Model.DepartmentsList ?? new List<UniManagementSystem.Application.DTOs.DashboardDtos.DepartmentDto>())
                {
                    <li>@dept.Name</li>
                }
            </ul>
        </div>

        <div class="card-accent">
            <h5>System State</h5>
            <p>Server Uptime: @Model.SystemState.ServerUptime</p>
            <p>Active Users: @Model.SystemState.ActiveUsers</p>
            <p>Database Status: @Model.SystemState.DatabaseStatus</p>
        </div>

    </main>
</div>